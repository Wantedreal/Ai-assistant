# Copy this file to .env and fill in your key.
# Never commit .env to source control.
#
# Get a free key at: https://openrouter.ai  (no credit card required)
# Free models: meta-llama/llama-3.1-8b-instruct:free  (default)
#              google/gemma-2-9b-it:free
#              mistralai/mistral-7b-instruct:free
#
# For the production .exe build, set _EMBEDDED_KEY in app/explainer.py instead.

OPENROUTER_API_KEY=your_key_here
