{
  "name": "battery-pack-designer",
  "version": "1.0.0",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:demo": "vite --mode demo",
    "build:demo": "vite build --mode demo",
    "dev:electron": "electron .",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "npm run build && electron .",
    "electron:build": "npm run build && electron-builder",
    "electron:build:win": "npm run build && electron-builder --win",
    "electron:build:mac": "npm run build && electron-builder --mac",
    "electron:build:linux": "npm run build && electron-builder --linux",
    "generate-icon": "node scripts/generate-icon.cjs"
  },
  "build": {
    "appId": "com.capgemini.batterypackdesigner",
    "productName": "Battery Pack Designer",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/**/*"
    ],
    "extraResources": [
      {
        "from": "../backend/dist/backend",
        "to": "backend",
        "filter": ["**/*"]
      }
    ],
    "icon": "build/icon",
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }],
      "category": "public.app-category.productivity",
      "icon": "build/icon.png"
    },
    "linux": {
      "target": [{ "target": "AppImage", "arch": ["x64"] }],
      "category": "Utility",
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerSidebar": null
    }
  },
  "dependencies": {
    "axios": "^1.6.0",
    "electron-is-dev": "^3.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.1.1",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "terser": "^5.46.1",
    "vite": "^5.0.0"
  }
}
