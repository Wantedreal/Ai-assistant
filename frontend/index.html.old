<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Julia Huang — AI-Driven Design</title>

  <!-- Gilroy via CDN (free weights) -->
  <link rel="preconnect" href="https://fonts.cdnfonts.com" />
  <link href="https://fonts.cdnfonts.com/css/gilroy-free" rel="stylesheet" />

  <!-- External CSS -->
  <link rel="stylesheet" href="styles.css" />
</head>

<body>

  <div class="page-wrapper">
    <!-- =====================================================
         NAVIGATION
         margin: 24px top/left/right via .page-wrapper padding
         margin-bottom: 14px via #site-header
    ====================================================== -->
    <header id="site-header">
      <nav class="nav-card" role="navigation" aria-label="Main navigation">

        <a href="/" class="nav-logo" aria-label="Julia Huang — home">
          <span class="nav-logo__first">Julia</span>
          <span class="nav-logo__last">Huang</span>
        </a>

        <ul class="nav-links" role="list">
          <li><a href="#projects">Projects</a></li>
          <li><a href="#about">About</a></li>
          <li><a href="#contact">Contact</a></li>
        </ul>

      </nav>
    </header>

    <!-- =====================================================
         MAIN BENTO GRID — cards added progressively
         left edge = same as header left edge (both share
         the 24px page-wrapper padding)
    ====================================================== -->
    <main class="page-content">

      <div class="bento-grid" id="bento-main">

        <!-- ── LEFT COLUMN ───────────────────────────────────── -->
        <div class="left-col">

          <!-- Projects card -->
          <div class="projects-card">
            <div class="projects-card__header">
              <span class="projects-card__label">Cell Selector</span>
            </div>

            <!-- Cell Dropdown -->
            <div style="padding: 16px 20px; border-bottom: 1px solid var(--color-border);">
              <label
                style="font-size: 0.75rem; font-weight: 600; display: block; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-muted);">Select
                Cell</label>
              <select class="modern-select">
                <option>Cell_001</option>
                <option>Cell_002</option>
                <option>Cell_003</option>
              </select>
            </div>

            <!-- Image Thumbnail -->
            <div class="projects-card__thumb" role="img" aria-label="Projects preview">
              <img src="images/Projectscard.png" alt="Projects Card"
                style="width: 100%; height: 100%; object-fit: cover;" />
            </div>

            <!-- Cell Specifications -->
            <div style="padding: 16px 20px;">
              <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 4px;">
                <div class="spec-badge">
                  <span class="spec-badge__label">Weight</span>
                  <span class="spec-badge__value">0.3 kg</span>
                </div>
                <div class="spec-badge">
                  <span class="spec-badge__label">Force</span>
                  <span class="spec-badge__value">0.3 N</span>
                </div>
                <div class="spec-badge">
                  <span class="spec-badge__label">Capacity</span>
                  <span class="spec-badge__value">5.0 Ah</span>
                </div>
                <div class="spec-badge">
                  <span class="spec-badge__label">Max Current</span>
                  <span class="spec-badge__value">10 A</span>
                </div>
              </div>
            </div>

            <ul class="projects-list" role="list"></ul>
          </div>

          <!-- Social card -->
          <div class="social-card">
            <div style="display: flex; flex-direction: row; gap: 12px; width: 100%;">
              <button class="modern-btn modern-btn-primary" style="flex: 1;">Calculate</button>
              <button class="modern-btn modern-btn-secondary" style="flex: 1;">Export PDF</button>
            </div>
          </div>

        </div>
        <!-- ── END LEFT COLUMN ───────────────────────────────── -->

        <!-- ── CENTER HEADLINE CARD ──────────────────────────── -->
        <!--  margin-left: 22px | margin-right: 28px (via CSS)   -->
        <div class="headline-card" style="min-height: auto;">
          <div style="padding: 24px; display: flex; flex-direction: column; gap: 14px;">

            <div style="text-align: center; margin-bottom: 8px;">
              <h2
                style="font-size: 1.1rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; margin: 0; color: rgba(0, 0, 0, 0.8);">
                Constraints</h2>
            </div>

            <!-- Housing Input -->
            <div style="display: flex; align-items: center; gap: 12px;">
              <label
                style="font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: rgba(0, 0, 0, 0.7); min-width: 90px;">Housing</label>
              <input type="text" value="800mm × 400mm" class="modern-input" />
            </div>

            <!-- Target Margin Input -->
            <div style="display: flex; align-items: center; gap: 12px;">
              <label
                style="font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: rgba(0, 0, 0, 0.7); min-width: 90px;">Target</label>
              <input type="text" value="15 mm" class="modern-input" />
            </div>

            <!-- Energy Target Input -->
            <div style="display: flex; align-items: center; gap: 12px;">
              <label
                style="font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: rgba(0, 0, 0, 0.7); min-width: 90px;">Energy</label>
              <input type="text" value="55 kW" class="modern-input" />
            </div>

            <!-- Current Input -->
            <div style="display: flex; align-items: center; gap: 12px;">
              <label
                style="font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: rgba(0, 0, 0, 0.7); min-width: 90px;">Current</label>
              <input type="text" value="350 A" class="modern-input" />
            </div>

          </div>
        </div>
        <!-- ── END CENTER HEADLINE CARD ──────────────────────── -->

        <!-- ── RIGHT PHOTO CARD ───────────────────────────────── -->
        <!-- right edge flush with header (page-wrapper 24px padding) -->
        <div class="photo-card" role="img" aria-label="Photo Card">
          <img src="images/ImageCard.png" alt="Photo Card" style="width: 100%; height: 100%; object-fit: cover;" />
        </div>
        <!-- ── END RIGHT PHOTO CARD ──────────────────────────── -->

        <!-- ── BOTTOM ROW — equal bio + contact ──────────────── -->
        <div class="bottom-row">

          <!-- Bio card -->

          <!-- Bio card -->
          <div class="bio-card">
            <div
              style="font-size: 1rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-accent); margin-bottom: 12px; display: flex; align-items: center; gap: 8px;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                stroke-linecap="round" stroke-linejoin="round">
                <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" />
              </svg>
              Electrical Results
            </div>
            <div style="font-size: 0.95rem; line-height: 1.8; color: var(--color-text);">
              <div
                style="display: flex; justify-content: space-between; border-bottom: 1px solid var(--color-overlay); padding-bottom: 6px; margin-bottom: 6px;">
                <span style="color: var(--color-muted);">Series/Parallel</span>
                <span style="font-weight: 600;">36S/10P</span>
              </div>
              <div
                style="display: flex; justify-content: space-between; border-bottom: 1px solid var(--color-overlay); padding-bottom: 6px; margin-bottom: 6px;">
                <span style="color: var(--color-muted);">Energy</span>
                <span style="font-weight: 600;">56.3 kWh</span>
              </div>
              <div
                style="display: flex; justify-content: space-between; border-bottom: 1px solid var(--color-overlay); padding-bottom: 6px; margin-bottom: 6px;">
                <span style="color: var(--color-muted);">Capacity</span>
                <span style="font-weight: 600;">50.0 Ah</span>
              </div>
              <div style="display: flex; justify-content: space-between;">
                <span style="color: var(--color-muted);">Maximum curr</span>
                <span style="font-weight: 600;">350 A</span>
              </div>
            </div>
          </div>

          <!-- Contact card -->
          <div class="contact-card">
            <div
              style="font-size: 1rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-accent); margin-bottom: 12px; display: flex; align-items: center; gap: 8px;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
              </svg>
              Mechanical Results
            </div>
            <div style="font-size: 0.95rem; line-height: 1.8; color: var(--color-text);">
              <div
                style="display: flex; justify-content: space-between; border-bottom: 1px solid var(--color-overlay); padding-bottom: 6px; margin-bottom: 6px;">
                <span style="color: var(--color-muted);">Module dimensions</span>
                <span style="font-weight: 600;">750 × 450 × 110mm</span>
              </div>
              <div
                style="display: flex; justify-content: space-between; border-bottom: 1px solid var(--color-overlay); padding-bottom: 6px; margin-bottom: 6px;">
                <span style="color: var(--color-muted);">Occupancy rate</span>
                <span style="font-weight: 600;">81.3%</span>
              </div>
              <div style="display: flex; justify-content: space-between;">
                <span style="color: var(--color-muted);">Margins</span>
                <span style="font-weight: 600;">25 mm</span>
              </div>
            </div>
          </div>

        </div>
        <!-- ── END BOTTOM ROW ─────────────────────────────────── -->

      </div>

    </main>

  </div>

</body>

</html>